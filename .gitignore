# R session and history files
.Rhistory
.Rapp.history
.RData

# Example code in R package build process
*-Ex.R

# Output files from R package build/check
/*.tar.gz
/*.Rcheck/

# RStudio local project files
.Rproj.user/

# OAuth2 tokens, secrets, and local environment files
.httr-oauth
.Renviron
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# knitr, R Markdown, and Quarto intermediate/cache files
/*_cache/
/cache/
.quarto/
*.utf8.md
*.knit.md

Rplots.pdf

# Operating-system and editor clutter
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python local environments/cache files, if a project adds Python later
.venv/
venv/
__pycache__/
.ipynb_checkpoints/

# renv local package libraries/state, if a project enables renv later
renv/library/
renv/staging/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/

# Local/private data files
# Commit readmes/placeholders, but keep private or large data local.
data/private-data/*
!data/private-data/readme-private-data.md
data/large-files/*
!data/large-files/readme-large-files.md

# Large generated result files
# Generated outputs are generally committed, but large outputs belong here.
results/large-files/*
!results/large-files/readme-large-files.md

# Local AI/tool state and scratch files
.ai-local/
.ai-cache/
.codex/
.claude/settings.local.json
.aider*
